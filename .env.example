# Environment variables read by `anthropic::Client::from_env`.
#
# Copy this file to `.env` and fill in the values you need. Only
# `ANTHROPIC_API_KEY` is required; everything else falls back to a default
# if the variable is unset.

# Required. Used as the `x-api-key` header on every request.
ANTHROPIC_API_KEY="sk-ant-..."

# Optional. Override the base URL (useful for local proxies / mock servers).
# Default: https://api.anthropic.com
# ANTHROPIC_API_BASE="https://api.anthropic.com"

# Optional. Sent as the `anthropic-version` header.
# Default: 2023-06-01
# ANTHROPIC_API_VERSION="2023-06-01"

# Optional. Sent as the `anthropic-beta` header when set.
# ANTHROPIC_BETA="prompt-caching-2024-07-31"

# Optional. Request timeout (seconds). Default: 60.
# ANTHROPIC_TIMEOUT_SECS="60"
